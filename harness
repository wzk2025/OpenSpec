#!/usr/bin/env bash
# harness — rd_harness 框架入口
# 用法:
#   ./harness setup    初始化本地环境（clone 后首次执行）
#   ./harness status   检查框架安装状态和版本
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SETUP="$SCRIPT_DIR/.claude/tools/scripts/setup/setup-harness.sh"

case "${1:-}" in
  setup)
    bash "$SETUP"
    ;;
  status)
    bash "$SETUP" --check
    ;;
  *)
    echo "用法: ./harness {setup|status}"
    echo ""
    echo "  setup    初始化本地开发环境（git clone 后首次执行）"
    echo "  status   检查框架安装状态和版本"
    exit 1
    ;;
esac
